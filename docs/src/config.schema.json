        },
        "details_sidecar": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "download_stems": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "format": {
          "anyOf": [
            {
              "$ref": "#/definitions/AudioFormat"
            },
            {
              "type": "null"
            }
          ]
        },
        "lrc_sidecar": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "lyrics_sidecar": {
          "type": [
