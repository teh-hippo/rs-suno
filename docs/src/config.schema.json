            "null"
          ]
        },
        "min_newest": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "naming_template": {
          "type": [
            "string",
            "null"
          ]
        },
        "number_singletons": {
          "description": "Whether a single-track (lone) lineage album is given a track number. When unset it defaults to `true`; `false` leaves singletons unnumbered so a `{track2}` prefix does not decorate a standalone song.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "retries": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "stem_format": {
          "anyOf": [
            {
              "$ref": "#/definitions/StemFormat"
            },
            {
              "type": "null"
            }
          ]
        },
        "token_command": {
          "description": "The command whose stdout mints a token. Resolved from the `SUNO_[<LABEL>_]TOKEN_COMMAND` env tiers then the config keys. There is deliberately no `--token-command` flag, so it is never read from [`FlagOverrides`]; set it in config or the environment.",
          "type": [
            "string",
            "null"
          ]
        },
        "video_cover_retention": {
          "anyOf": [
            {
              "$ref": "#/definitions/VideoCoverRetention"
            },
            {
              "type": "null"
            }
          ]
        },
        "video_mp4": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "SourceMode": {
      "description": "How a selected source treats its clips: mirror with deletion, or additive copy.",
      "oneOf": [
        {
          "description": "Mirror the source, deleting local files that leave it (rclone `sync`).",
          "type": "string",
          "enum": [
            "mirror"
          ]
        },
        {
          "description": "Copy additively; never delete (rclone `copy`).",
          "type": "string",
          "enum": [
            "copy"
          ]
        }
      ]
    },
    "StemFormat": {
      "description": "Container format for a downloaded stem.\n\nStems are stored RAW in their native container and are never transcoded, so unlike [`AudioFormat`] there is no lossless-from-lossy render: WAV comes straight from Suno's free `convert_wav` endpoint and MP3 straight from the public CDN. FLAC is deliberately unrepresentable — a stem is never re-encoded to FLAC, even when the song's own format is FLAC.",
      "oneOf": [
        {
          "description": "Lossless WAV via the free `convert_wav` render, stored as delivered.",
          "type": "string",
          "enum": [
            "wav"
          ]
        },
        {
          "description": "The public CDN MP3, stored as delivered.",
          "type": "string",
          "enum": [
            "mp3"
          ]
        }
      ]
    },
    "VideoCoverRetention": {
      "description": "Which video-cover artifacts to retain.",
      "type": "string",
      "enum": [
        "neither",
        "webp",
        "mp4",
        "both"
      ]
    }
  }
}
