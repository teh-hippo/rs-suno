{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": false,
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true
    }
  },
  "extra-files": [
    {
      "type": "toml",
      "path": "Cargo.toml",
      "jsonpath": "$.workspace.package.version"
    },
    {
      "type": "toml",
      "path": "crates/rs-suno/Cargo.toml",
      "jsonpath": "$.dependencies.suno-core.version"
    },
    {
      "type": "toml",
      "path": "Cargo.lock",
      "jsonpath": "$.package[?(@.name.value == \"suno-core\")].version"
    },
    {
      "type": "toml",
      "path": "Cargo.lock",
      "jsonpath": "$.package[?(@.name.value == \"rs-suno\")].version"
    }
  ]
}
